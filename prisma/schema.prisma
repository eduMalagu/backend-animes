generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Personagem {
  id             Int      @id @default(autoincrement())
  nome           String
  obra           String
  categoria      String
  descricao      String?
  poderPrincipal String?
  idade          Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([nome, obra])
}
